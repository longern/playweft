# Leave empty when the frontend and Worker share an origin.
# For a separately hosted frontend, point to the Worker origin.
VITE_API_BASE_URL=http://127.0.0.1:8787

# Optional. Defaults to code:4 and should match the Worker ROOM_ID_FORMAT.
# Supports code:N, digits:N, base64url:N, or uuid.
# VITE_ROOM_ID_FORMAT=code:4
